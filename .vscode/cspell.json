// cSpell Settings
{
    // Version of the setting file.  Always 0.2
    "version": "0.2",
    // language - current active spelling language
    "language": "en",
    // words - list of words to be always considered correct
    // prettier-ignore
    "words": [
        "CODEOWNERS",
        "deepskyblue",
        "endregion",
        "eqeqeq",
        "exfiltration",
        "fluentui",
        "Inkscape",
        "linebreak",
        "magick",
        "markdownlint",
        "minifier",
        "openpgp",
        "ploc",
        "prettierrc",
        "telemetryservice",
        "testid",
        "wandyezj"
    ],
    // flagWords - list of words to be always considered incorrect
    // This is useful for offensive words and common spelling errors.
    // For example "hte" should be "the"
    "dictionaryDefinitions": [
        {
            "name": "ai-model-names",
            "path": "./cspell/ai-model-names.words.txt"
        },
        {
            "name": "office-add-in",
            "path": "./cspell/office-add-in.words.txt"
        }
    ],
    "dictionaries": ["ai-model-names", "office-add-in"],
    "flagWords": [],
    "ignorePaths": ["localize/strings.tsv", "src/core/localize/strings.json"]
}
